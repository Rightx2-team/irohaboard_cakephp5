# Credentials and environment-specific files / 機密情報・環境依存ファイル
/config/app_local.php
/.env

# Docker local overrides (differ per environment) / Docker ローカル設定（環境ごとに異なるため）
/docker-compose.override.yml

# Dependencies (regenerated by composer install) / 依存パッケージ（composer install で再生成可能）
/vendor/

# Cache, logs and temp files / キャッシュ・ログ・一時ファイル
/tmp/*
/logs/*
!/tmp/cache/
!/tmp/cache/models/
!/tmp/cache/persistent/
!/tmp/cache/views/
!/tmp/.gitkeep
!/logs/.gitkeep

# Uploaded user files / アップロードファイル（ユーザーデータ）
/files/*
!/files/.gitkeep
/webroot/files/*
!/webroot/files/.gitkeep
/webroot/uploads/*
!/webroot/uploads/.gitkeep

# OS and editor generated files / OS・エディタ生成ファイル
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
