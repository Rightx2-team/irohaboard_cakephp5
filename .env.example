# Application settings / アプリケーション設定
APP_PORT=80
APP_DEBUG=false
SECURITY_SALT=change_this_to_a_long_random_string_32chars_or_more

# Database settings / データベース設定
DB_ROOT_PASSWORD=rootpassword
DB_DATABASE=irohaboard
DB_USERNAME=irohaboard
DB_PASSWORD=change_this_password

# Local dev only: expose DB port to host / ローカル開発用: DBポートをホストに公開
DB_PORT=3306
